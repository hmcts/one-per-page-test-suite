{
  "name": "@hmcts/one-per-page-test-suite",
  "description": "Testing framwork for @hmcts/one-per-page",
  "homepage": "https://github.com/hmcts/one-per-page-test-suite#readme",
  "main": "./index.js",
  "version": "7.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hmcts/one-per-page-test-suite.git"
  },
  "bugs": {
    "url": "https://github.com/hmcts/one-per-page-test-suite/issues"
  },
  "engines": {
    "node": ">=10.12.0"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "NODE_PATH=. nyc mocha --exit 'test/**/*.test.js'",
    "audit:check": "chmod +x bin/audit-check.sh && ./bin/audit-check.sh",
    "coverage": "nyc check-coverage"
  },
  "pre-commit": [
    "lint"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hmcts/look-and-feel": "^6.0.1",
    "@hmcts/one-per-page": "^7.0.0",
    "cookie-parser": "^1.4.3",
    "domino": "^2.0.2",
    "express": "5.2.1",
    "express-nunjucks": "^2.2.3",
    "html-entities": "^1.2.1",
    "jquery": "^3.2.1",
    "lodash": "4.18.1",
    "zepto-node": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@hmcts/eslint-config": "^1.3.0",
    "chai": "^4.1.2",
    "chai-as-promised": "^7.1.1",
    "chai-jq": "^0.0.9",
    "codacy-coverage": "^3.4.0",
    "config": "^2.0.1",
    "eslint": "10.0.2",
    "eslint-plugin-mocha": "^11.2.0",
    "globals": "^17.5.0",
    "http-status-codes": "^2.3.0",
    "mocha": "^8.0.1",
    "mocha-param": "^2.0.0",
    "nyc": "^18.0.0",
    "proxyquire": "^1.8.0",
    "sinon": "^5.0.7",
    "sinon-chai": "^3.0.0",
    "supertest": "^3.1.0"
  },
  "resolutions": {
    "rimraf": "^4.0.0",
    "router": "2.2.0",
    "glob": "^13.0.0"
  },
  "nyc": {
    "report-dir": "coverage",
    "temp-directory": "./coverage/.nyc_output",
    "check-coverage": true,
    "per-file": true,
    "lines": 80,
    "statements": 80,
    "functions": 80,
    "reporter": [
      "lcov",
      "text"
    ],
    "sourceMap": true,
    "instrument": true,
    "exclude": [
      "test/**/*",
      "node_modules",
      "coverage",
      ".nyc_output",
      "index.js",
      "utils",
      ".yarn/**",
      "eslint.config.mjs"
    ],
    "all": true
  },
  "packageManager": "yarn@4.10.0"
}
